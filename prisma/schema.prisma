generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BuildingStatus {
  draft
  published
  archived
}

enum UnitStatus {
  available
  reserved
  sold
  hidden
}

enum UnitKind {
  apartment
  parking
}

enum LeadStatus {
  new
  contacted
  qualified
  viewing_booked
  reserved
  closed
  archived
  spam
}

enum PriceVisibilityMode {
  visible
  hidden
  per_unit
}

enum ParkingStatus {
  available
  reserved
  sold
  hidden
}

model Building {
  id               String         @id
  slug             String         @unique
  name             String
  shortDescription String
  fullDescription  String
  status           BuildingStatus @default(published)
  displayOrder     Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  floors           Floor[]
  units            Unit[]
  parkingSpots     ParkingSpot[]
  leads            Lead[]
  events           Event[]
  siteSettings     SiteSettings[]
  legalPages       LegalPage[]
}

model Floor {
  id             String   @id
  buildingId     String
  number         Int
  label          String
  description    String
  floorplanImage String
  mapAspectRatio String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  building       Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  units          Unit[]

  @@unique([buildingId, number])
}

model Unit {
  id              String     @id
  kind            UnitKind   @default(apartment)
  externalCode    String     @unique
  slug            String     @unique
  buildingId      String
  floorId         String?
  typologyId      String?
  unitNumber      String
  rooms           Int
  bedrooms        Int?
  bathrooms       Int
  areaLivingSqm   Float      @default(0)
  areaSharedSqm   Float      @default(0)
  areaTotalSqm    Float      @default(0)
  terraceSqm      Float      @default(0)
  commonPartsPercent Float    @default(0)
  landPercent     Float      @default(0)
  landAreaSqm     Float      @default(0)
  areaInternalSqm Float      @default(0)
  hasYard         Boolean    @default(false)
  outdoorType     String?
  orientation     String
  exposure        String
  price           Float?
  currency        String     @default("EUR")
  status          UnitStatus @default(available)
  isPublished     Boolean    @default(true)
  isPriceVisible  Boolean    @default(true)
  description     String
  highlight       String
  floorplan       String
  gallery         String[]
  panoramaImage   String?
  features        String[]
  planArea        Json?
  planRegions     Json?
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  building        Building   @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor           Floor?     @relation(fields: [floorId], references: [id], onDelete: SetNull)
  leads           Lead[]
  events          Event[]

  @@index([buildingId, kind, status, isPublished])
  @@index([slug])
}

model ParkingSpot {
  id         String        @id
  buildingId String
  code       String        @unique
  levelLabel String?
  areaSqm    Float?
  price      Float?
  currency   String        @default("EUR")
  status     ParkingStatus @default(available)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  building   Building      @relation(fields: [buildingId], references: [id], onDelete: Cascade)
}

model Lead {
  id               String     @id @default(uuid())
  fullName         String
  email            String
  phone            String?
  message          String?
  unitId           String?
  buildingId       String?
  sourcePageUrl    String
  referrer         String?
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  utmTerm          String?
  utmContent       String?
  userAgentHash    String?
  ipHash           String?
  consentTimestamp DateTime
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  status           LeadStatus @default(new)
  adminNotes       String?
  unit             Unit?      @relation(fields: [unitId], references: [id], onDelete: SetNull)
  building         Building?  @relation(fields: [buildingId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status])
  @@index([email])
}

model SiteSettings {
  id                  String              @id @default("default")
  buildingId          String?
  priceVisibilityMode PriceVisibilityMode @default(per_unit)
  contactEmail        String?
  contactPhone        String?
  bookingUrl          String?
  announcement        String?
  analyticsEnabled    Boolean             @default(true)
  cookieConsentMode   String              @default("explicit")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  building            Building?           @relation(fields: [buildingId], references: [id], onDelete: SetNull)
}

model LegalPage {
  id             String    @id @default(cuid())
  buildingId     String?
  slug           String
  locale         String    @default("bg")
  title          String
  body           String
  isPublished    Boolean   @default(true)
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  building       Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)

  @@unique([slug, locale])
  @@index([isPublished, slug])
}

model AdminUser {
  id              String    @id @default(cuid())
  username        String    @unique
  passwordHash    String
  role            String    @default("super_admin")
  totpSecret      String?
  totpEnabled     Boolean   @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Event {
  id            String    @id @default(cuid())
  eventType     String
  sourcePageUrl String
  referrer      String?
  source        String?
  medium        String?
  campaign      String?
  term          String?
  content       String?
  deviceType    String?
  country       String?
  region        String?
  city          String?
  durationMs    Int?
  visitorIdHash String?
  sessionIdHash String?
  buildingId    String?
  unitId        String?
  payload       Json?
  userAgentHash String?
  ipHash        String?
  createdAt     DateTime  @default(now())
  building      Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  unit          Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([eventType])
  @@index([country])
  @@index([city])
  @@index([buildingId])
  @@index([unitId])
  @@index([visitorIdHash])
  @@index([sessionIdHash])
}
